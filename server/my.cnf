[mysqld]
# ========== 基础设置 ==========
port                          = 3306
user                          = mysql
server-id                     = 1
# 禁止 DNS 反向解析，避免连接卡顿，同时提升安全性
skip-name-resolve
# 设置时区为中国时区
default-time-zone             = '+8:00'

# ========== 字符集（MySQL 8.4 默认即为 utf8mb4，显式声明便于维护） ==========
character-set-server          = utf8mb4
collation-server              = utf8mb4_0900_ai_ci

# ========== 连接数 ==========
# 400人公司、多应用共享，100 足够（默认151偏小）
max_connections               = 100
# 空闲连接超时 10 分钟，自动回收泄漏连接
wait_timeout                  = 600
interactive_timeout           = 600

# ========== InnoDB 引擎（核心性能参数） ==========
# 缓冲池大小，建议为服务器总内存的 50%~60%
# 服务器 4G 内存 → 设 1G
# 请根据实际服务器内存调整此值！
innodb_buffer_pool_size       = 1G
# 每张表独立表空间，便于单表管理和回收空间
innodb_file_per_table         = 1
# 事务提交时刷盘策略：1=最安全（每次提交都刷盘），0/2=性能更好但可能丢数据
innodb_flush_log_at_trx_commit = 1
# Redo Log 大小，影响崩溃恢复时间和写入吞吐
innodb_redo_log_capacity      = 256M

# ========== 日志 ==========
# 错误日志
log-error                     = /var/log/mysql/error.log
# 慢查询日志（排查性能问题的关键）
slow_query_log                = 1
slow_query_log_file           = /var/log/mysql/slow.log
long_query_time               = 2
# 记录未使用索引的查询
log_queries_not_using_indexes = 0

# ========== 二进制日志（用于增量备份和恢复） ==========
# MySQL 8.4 默认已开启 binlog，这里显式配置格式
binlog_format                 = ROW
binlog_expire_logs_seconds    = 604800
# 7 天后自动清理过期 binlog

# ========== SQL 模式 ==========
sql_mode                      = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION

# ========== 安全 ==========
# MySQL 8.4 默认认证插件为 caching_sha2_password，无需也无法使用旧的
# default-authentication-plugin 参数（8.4 已移除，用了会启动失败）

[client]
default-character-set         = utf8mb4

[mysql]
default-character-set         = utf8mb4
